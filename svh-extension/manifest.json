{
  "manifest_version": 3,
  "name": "Scriptcase Versioning Hub",
  "version": "1.0.0",
  "permissions": ["storage", "alarms", "scripting", "webRequest", "webNavigation"],
  "host_permissions": ["*://*/*"],
  "background": { 
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["*://*/scriptcase/devel/*"],
    "js": ["content/injector.js"],
    "all_frames": true,
    "run_at": "document_idle"
  }],
  "options_page": "options.html",
  "action": { "default_popup": "popup.html" },
  "web_accessible_resources": [{
    "resources": [
      "inject/fetch-patch.js",
      "inject/editor-bridge-main.js",
      "vendor/diff2html.min.css",
      "vendor/highlight-github.min.css"
    ],
    "matches": ["<all_urls>"]
  }]
}
